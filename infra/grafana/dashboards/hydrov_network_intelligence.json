{
  "title": "🧠 HYDRO-V — Network Intelligence (GNN)",
  "uid": "hydrov-network-intelligence",
  "description": "Visualización de detecciones de fugas del modelo GNN de Emma. Requiere tabla leak_detections en PostgreSQL.",
  "tags": ["hydrov", "gnn", "leaks", "ai"],
  "timezone": "America/Mexico_City",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "links": [
    {"title": "← Mission Control", "url": "/d/hydrov-mission-control", "type": "link", "icon": "arrow-left"}
  ],
  "templating": {
    "list": [
      {
        "name": "device_id",
        "label": "Nodo",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
        "query": "SELECT device_id FROM devices WHERE is_active = true ORDER BY device_id",
        "current": {"text": "All", "value": "$__all"},
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "⚠️ Detecciones de Fuga Activas",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM leak_detections WHERE resolved = false AND detected_at > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Fugas activas",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#4CAF50", "value": null},
              {"color": "#FF9800", "value": 1},
              {"color": "#F44336", "value": 3}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "📊 Score de Anomalía Promedio",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(anomaly_score)::numeric, 3) AS value FROM leak_detections WHERE detected_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "displayName": "Score medio (1h)",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#4CAF50", "value": null},
              {"color": "#FF9800", "value": 0.50},
              {"color": "#F44336", "value": 0.75}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "🔍 Tabla de Detecciones — Últimas 50",
      "type": "table",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT node_id AS \"Nodo\", detected_at AT TIME ZONE 'America/Mexico_City' AS \"Detectado\", ROUND(CAST(anomaly_score * 100 AS numeric), 1) AS \"Score (%)\", CASE WHEN anomaly_score >= 0.95 THEN 'CRÍTICA' WHEN anomaly_score >= 0.85 THEN 'ALTA' ELSE 'MEDIA' END AS \"Severidad\", resolved AS \"Resuelta\" FROM leak_detections ORDER BY detected_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "options": {
        "footer": {"show": true, "reducer": ["count"], "fields": ["Score (%)"]},
        "sortBy": [{"displayName": "Detectado", "desc": true}]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Severidad"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"CRÍTICA": {"text": "🔴 CRÍTICA", "color": "#F44336"}}},
                  {"type": "value", "options": {"ALTA":    {"text": "🟠 ALTA",    "color": "#FF9800"}}},
                  {"type": "value", "options": {"MEDIA":   {"text": "🟡 MEDIA",   "color": "#FFC107"}}}
                ]
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Resuelta"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"true":  {"text": "✅ Sí", "color": "#4CAF50"}}},
                  {"type": "value", "options": {"false": {"text": "🚨 No", "color": "#F44336"}}}
                ]
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Score (%)"},
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#4CAF50", "value": null},
                    {"color": "#FFC107", "value": 50},
                    {"color": "#FF9800", "value": 75},
                    {"color": "#F44336", "value": 85}
                  ]
                }
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "📈 Score de Anomalía en el Tiempo",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT detected_at AS time, node_id, anomaly_score AS value FROM leak_detections WHERE $__timeFilter(detected_at) ORDER BY detected_at",
          "format": "time_series"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": {"mode": "line+area"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "transparent", "value": null},
              {"color": "rgba(244,67,54,0.25)", "value": 0.75}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "🗺️ Mapa de Calor de Riesgo por Nodo",
      "type": "geomap",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 22},
      "datasource": {"type": "postgres", "uid": "${DS_HYDROV-POSTGRESQL}"},
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT d.device_id, d.name, d.lat AS latitude, d.lon AS longitude, COALESCE(AVG(l.anomaly_score), 0) AS risk_score FROM devices d LEFT JOIN leak_detections l ON d.device_id = l.node_id AND l.detected_at > NOW() - INTERVAL '1 hour' WHERE d.is_active = true GROUP BY d.device_id, d.name, d.lat, d.lon",
          "format": "table"
        }
      ],
      "options": {
        "view": {"id": "coords", "lat": 19.4136, "lon": -99.0151, "zoom": 13},
        "basemap": {
          "type": "xyz",
          "config": {
            "url": "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
            "attribution": "CartoDB Dark Matter"
          }
        },
        "layers": [
          {
            "type": "heatmap",
            "name": "Riesgo de Fuga",
            "config": {
              "weight": {"field": "risk_score", "fixed": 1},
              "radius": 30,
              "blur": 15,
              "opacity": 0.8
            }
          },
          {
            "type": "markers",
            "name": "Nodos",
            "config": {
              "style": {
                "size": {"fixed": 8},
                "color": {"field": "risk_score"},
                "symbol": {"fixed": "img/icons/marker/circle.svg"},
                "fillOpacity": 1.0
              },
              "showTooltip": true
            }
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "risk_score"},
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu",
                  "min": 0,
                  "max": 1
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
