{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "__inputs": [
    {
      "name": "DS_HYDROV-TIMESERIES",
      "label": "HydroV-TimeSeries",
      "type": "datasource",
      "pluginId": "influxdb"
    },
    {
      "name": "DS_HYDROV-POSTGRESQL",
      "label": "HydroV-PostgreSQL",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ],
  "title": "\ud83d\udef0\ufe0f HYDRO-V \u2014 Mission Control",
  "uid": "hydrov-mission-control",
  "description": "Control center principal del sistema Hydro-V. Telemetr\u00eda en tiempo real, estado FSM, calidad del agua y mapa de nodos.",
  "tags": [
    "hydrov",
    "telemetry",
    "real-time"
  ],
  "timezone": "America/Mexico_City",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "Node Deep Dive",
      "url": "/d/hydrov-node-deep-dive",
      "type": "link",
      "icon": "external link"
    },
    {
      "title": "Network Intelligence",
      "url": "/d/hydrov-network-intelligence",
      "type": "link",
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "device_id",
        "label": "Nodo",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "hydrov-postgres"
        },
        "query": "SELECT device_id FROM devices WHERE is_active = true ORDER BY device_id",
        "current": {
          "text": "HYDRO-V-001",
          "value": "HYDRO-V-001"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Alertas EMERGENCY",
        "datasource": {
          "type": "postgres",
          "uid": "hydrov-postgres"
        },
        "rawQuery": true,
        "rawSql": "SELECT EXTRACT(EPOCH FROM timestamp) * 1000 AS time, 'EMERGENCY' AS text, node_id AS tags FROM emergency_alerts WHERE node_id = '${device_id}' AND $__timeFilter(timestamp)",
        "enable": true,
        "hide": false,
        "iconColor": "#F44336",
        "step": "60s"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Estado del Sistema",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "hydrov-influx-telemetry"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"sensor_telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"device_state\")\n  |> filter(fn: (r) => r.device_id == \"${device_id}\")\n  |> filter(fn: (r) => r._field == \"fsm_state\")\n  |> last()",
          "datasource": {
            "type": "influxdb",
            "uid": "hydrov-influx-telemetry"
          }
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "text": {
          "titleSize": 12,
          "valueSize": 28
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "IDLE": {
                  "text": "\u23f8  IDLE",
                  "color": "#9E9E9E",
                  "index": 0
                },
                "ANALYZING": {
                  "text": "\ud83d\udd2c ANALIZANDO",
                  "color": "#2196F3",
                  "index": 1
                },
                "HARVESTING": {
                  "text": "\ud83d\udca7 COSECHANDO",
                  "color": "#4CAF50",
                  "index": 2
                },
                "FULL_TANK": {
                  "text": "\u2705 CISTERNA LLENA",
                  "color": "#00BCD4",
                  "index": 3
                },
                "EMERGENCY": {
                  "text": "\ud83d\udea8 EMERGENCIA",
                  "color": "#F44336",
                  "index": 4
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#9E9E9E",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "\ud83d\udca7 Nivel de Cisterna",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "hydrov-influx-telemetry"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"sensor_telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"sensor_reading\")\n  |> filter(fn: (r) => r.device_id == \"${device_id}\")\n  |> filter(fn: (r) => r._field == \"distance_cm\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: (100.0 - r._value) / 100.0 * 100.0}))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#F44336",
                "value": null
              },
              {
                "color": "#FF9800",
                "value": 20
              },
              {
                "color": "#FFC107",
                "value": 50
              },
              {
                "color": "#4CAF50",
                "value": 80
              }
            ]
          },
          "decimals": 1,
          "displayName": "Nivel"
        }
      }
    },
    {
      "id": 3,
      "title": "\ud83c\udf0a Turbidez del Agua",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 5,
        "y": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "hydrov-influx-telemetry"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"sensor_telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"sensor_reading\")\n  |> filter(fn: (r) => r.device_id == \"${device_id}\")\n  |> filter(fn: (r) => r._field == \"turbidity_ntu\")\n  |> last()"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 200,
          "decimals": 1,
          "displayName": "NTU",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#4CAF50",
                "value": null
              },
              {
                "color": "#FF9800",
                "value": 5
              },
              {
                "color": "#FF5722",
                "value": 15
              },
              {
                "color": "#F44336",
                "value": 50
              }
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 5,
                "result": {
                  "text": "LIMPIA \u2713",
                  "color": "#4CAF50"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 5,
                "to": 15,
                "result": {
                  "text": "ACEPTABLE",
                  "color": "#FF9800"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 15,
                "to": 50,
                "result": {
                  "text": "TURBIA",
                  "color": "#FF5722"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 50,
                "to": 9999,
                "result": {
                  "text": "RECHAZADA \u2717",
                  "color": "#F44336"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "\ud83d\udebf Caudal Actual",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
