      "datasource": {
        "type": "influxdb",
        "uid": "hydrov-influx-telemetry"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"sensor_telemetry\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"sensor_reading\")\n  |> filter(fn: (r) => r.device_id == \"${device_id}\")\n  |> filter(fn: (r) => r._field == \"flow_lpm\")\n  |> aggregateWindow(every: 30s, fn: mean)"
        }
      ],
