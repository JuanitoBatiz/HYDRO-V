# infra/.env.template
# ─────────────────────────────────────────────────────────────────
#  Template de variables de entorno para PRODUCCIÓN
#  Copiar como .env en hydrov-backend/ y rellenar los valores reales
#  NUNCA commitear este archivo con valores reales
# ─────────────────────────────────────────────────────────────────

# ── Aplicación ────────────────────────────────────────────────────
DEBUG=False
ENVIRONMENT=production

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hydrov
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA_EN_PRODUCCION
POSTGRES_DB=hydrov

# ── InfluxDB ──────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=CAMBIAR_POR_TOKEN_DE_INFLUXDB_REAL
INFLUX_ORG=hydrov
INFLUX_BUCKET_TELEMETRY=sensor_telemetry
INFLUX_BUCKET_NASA=nasa_weather_cache

# Para el setup inicial de InfluxDB (solo primera vez)
INFLUX_ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN_INFLUX

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_REDIS_SEGURA
REDIS_DB=0

# ── MQTT / HiveMQ Cloud ───────────────────────────────────────────
# Obtener en: https://console.hivemq.cloud
MQTT_HOST=TU-CLUSTER.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=TU_USUARIO_HIVEMQ
MQTT_PASSWORD=TU_PASSWORD_HIVEMQ

# ── NASA POWER ────────────────────────────────────────────────────
# Coordenadas del deployment (Nezahualcóyotl por defecto)
NASA_DEFAULT_LAT=19.4136
NASA_DEFAULT_LON=-99.0151

# ── Seguridad / JWT ───────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERAR_CON_SECRETS_TOKEN_HEX_32

# ── Schedulers NASA POWER (mantener defaults en prod) ────────────
NASA_SCHEDULER_HOURLY_INTERVAL=1
NASA_SCHEDULER_DAILY_CRON_HOUR=6
